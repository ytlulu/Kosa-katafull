        if SpyOn then spyFlushFile() end
    end
end)

local function spySaveWord(word)
    if not word or word == "" then return end
    word = string.lower(word:match("^%s*(.-)%s*$") or "")
    if word == "" or #word < 3 then return end
    -- O(1) — sudah ada di kosa kata utama?
    if kosaKataSet[word] then return end
    -- O(1) — sudah pernah dicatat spy?
    if spyWords[word] then return end
    spyWords[word] = true
    table.insert(spyList, word)
    table.insert(FIND_WORDS, word)   -- masuk pool temporary FindWord
    kosaKataSet[word] = true         -- O(1) lookup, tidak ditemukan 2x
    spyDirty = true
    spyLbl_Count.Text = "Collected : " .. #spyList
end

local function spyWatchPlayer(player)
    if spyWatching[player] then return end
    spyWatching[player] = true

    local thread = task.spawn(function()
        local char = player.Character or player.CharacterAdded:Wait()
        local head = char:WaitForChild("Head", 10)
        if not head then spyWatching[player] = nil return end

        local lastText  = ""
        local firstSeen = nil
        local lastLabel = nil

        while SpyOn and player and player.Parent and char.Parent do
            task.wait(0.15)
            local billboard = head:FindFirstChild("TurnBillboard")
            local label = billboard and billboard:FindFirstChildWhichIsA("TextLabel", true)

            if label and label.Text and label.Text ~= "" then
                local text = label.Text:match("^%s*(.-)%s*$") or ""
                if text ~= "" then
                    if text ~= lastText then
                        lastText  = text
                        firstSeen = os.clock()
                    end
                    lastLabel = text
                end
            else
                if lastLabel and firstSeen then
                    local duration = os.clock() - firstSeen
                    if duration < 14 then
                        spySaveWord(lastLabel)
                    end
                end
                lastLabel = nil
                lastText  = ""
                firstSeen = nil
            end
        end
        spyWatching[player] = nil
    end)
    spyThreads[player] = thread
end

local function spyStartAll()
    for _, p in ipairs(Players:GetPlayers()) do
        spyWatchPlayer(p)
    end
end

local function spyStopAll()
    for p, thread in pairs(spyThreads) do
        pcall(task.cancel, thread)
        spyWatching[p] = nil
    end
    spyThreads  = {}
    spyWatching = {}
end

local charConnections = {}

Players.PlayerAdded:Connect(function(p)
    if SpyOn then spyWatchPlayer(p) end
    charConnections[p] = p.CharacterAdded:Connect(function()
        if SpyOn then
            spyWatching[p] = nil
            spyWatchPlayer(p)
        end
    end)
end)

Players.PlayerRemoving:Connect(function(p)
    if charConnections[p] then
        charConnections[p]:Disconnect()
        charConnections[p] = nil
    end
    if spyThreads[p] then
        pcall(task.cancel, spyThreads[p])
        spyThreads[p]  = nil
        spyWatching[p] = nil
    end
end)

