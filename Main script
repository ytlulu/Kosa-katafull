local function DetectPlayer()
    if LocalPlayer.Character then
        return LocalPlayer.Character.Name
    end
    return nil
end

local function GetBoardPrefix()
    if AutoDetect then Username = DetectPlayer() end
    if not Username or Username == "" then return nil end
    local ok, prefix = pcall(function()
        local target = workspace:FindFirstChild(Username)
        if not target then return nil end
        local head = target:FindFirstChild("Head")
        if not head then return nil end
        local billboard = head:FindFirstChild("TurnBillboard")
        if not billboard then return nil end
        local label = billboard:FindFirstChildWhichIsA("TextLabel", true)
        if not label then return nil end
        local text = label.Text
        if not text or text == "" then return nil end
        return string.upper(text:match("^%s*(.-)%s*$") or "")
    end)
    if ok and prefix and #prefix > 0 then return prefix end
    return nil
end

local function WordLengthOK(word)
    if WordLength == "Short" then return #word <= 4 end
    if WordLength == "Long"  then return #word >= 6 end
    return true
end

local function FindWord(prefix)
    if not prefix or #prefix == 0 then return nil end
    local lowerPrefix = string.lower(prefix)
    local firstLetter = string.upper(string.sub(prefix, 1, 1))

    local function searchIn(index)
        local candidates = index[firstLetter] or {}
        local picked = nil
        local count  = 0

        local function tryPick(word)
            if string.sub(word, 1, #lowerPrefix) ~= lowerPrefix then return end
            if UsedWords[word] or SavedWords[word] or FailWords[word] then return end
            if not WordLengthOK(word) then return end
            if CounterOn and CounterSuffix ~= "" then
                local suffix = string.lower(CounterSuffix)
                if string.sub(word, -#suffix) ~= suffix then return end
            end
            count = count + 1
            if math.random(count) == 1 then picked = word end
        end

        for _, word in ipairs(candidates) do tryPick(word) end

        -- Fallback: abaikan suffix kalau tidak ada yang cocok
        if not picked and CounterOn and CounterSuffix ~= "" then
            count = 0
            for _, word in ipairs(candidates) do
                if string.sub(word, 1, #lowerPrefix) == lowerPrefix
                    and not UsedWords[word] and not SavedWords[word] and not FailWords[word]
                    and WordLengthOK(word) then
                    count = count + 1
                    if math.random(count) == 1 then picked = word end
                end
            end
        end

        return picked
    end

    if PriorityOn and SelectedPriorityName ~= "" then
        local src = sourceData[SelectedPriorityName]
        if src and src.index then
            local picked = searchIn(src.index)
            if picked then
                UsedWords[picked] = true
                return picked
            end
        end
    end

    local picked = searchIn(KATA_INDEX)
    if picked then UsedWords[picked] = true return picked end

    -- Fallback: cari di pool temporary spy words
    if #FIND_WORDS > 0 then
        local spyIndex = BuildSourceIndex(FIND_WORDS)
        picked = searchIn(spyIndex)
        if picked then UsedWords[picked] = true return picked end
    end

    return nil
end

local function Submit(bill, sum)
    local sisa = string.sub(sum, #bill + 1)
    pcall(function()
        ReplicatedStorage.Remotes.SubmitWord:FireServer(sisa)
    end)
    SavedWords[sum] = true
    TotalUsed = TotalUsed + 1
end

local function PlayNormal(bill, word)
    if not word then return end
    task.wait(CFG.Delay)
    local sisa = string.sub(word, #bill + 1)
    for i = 1, #sisa do
        if not IsRunning then return end
        local partial = string.sub(sisa, 1, i)
        pcall(function()
            ReplicatedStorage.Remotes.BillboardUpdate:FireServer(partial)
        end)
        task.wait(CFG.Speed)
    end
    task.wait(0.1)
    Submit(bill, word)
end

local function PlayMid(bill, word)
    if not word then return end
    task.wait(CFG.Delay)
    local sisa = string.sub(word, #bill + 1)
    pcall(function()
        ReplicatedStorage.Remotes.BillboardUpdate:FireServer(sisa)
    end)
    task.wait(0.2)
    Submit(bill, word)
end

local function PlayRisk(bill, word)
    if not word then return end
    task.wait(CFG.Delay)
    Submit(bill, word)
end

local function StartAuto()
    if IsRunning then return end
    IsRunning = true
    CurrentSum = "idle"
    AutoTask = task.spawn(function()
        local lockedPrefix = nil
        while IsRunning do
            local prefix = GetBoardPrefix()

            if not prefix then
                lockedPrefix = nil
                CurrentSum = "standby"
                task.wait(0.3)
                continue
            end

            if not lockedPrefix then
                lockedPrefix = prefix
                UsedWords = {}
            end

            if prefix ~= lockedPrefix and not (prefix:sub(1, #lockedPrefix) == lockedPrefix) then
                lockedPrefix = prefix
                UsedWords = {}
            end

            CurrentBill = lockedPrefix
            local word = FindWord(lockedPrefix)
            if not word then
                CurrentSum = "no candidates"
                task.wait(0.3)
                continue
            end

            CurrentSum = word

            if SelectedMode == "Normal" then
                PlayNormal(lockedPrefix, word)
            elseif SelectedMode == "Mid" then
                PlayMid(lockedPrefix, word)
            else
                PlayRisk(lockedPrefix, word)
            end

            local retryWord = word
            while IsRunning do
                task.wait(0.5)
                local boardNow = GetBoardPrefix()

                if not boardNow then
                    -- Board kosong = giliran selesai, kata diterima
                    lockedPrefix = nil
                    break
                end

                -- Kalau prefix sudah BERUBAH = kata diterima, lanjut loop utama
                if boardNow ~= lockedPrefix then
                    lockedPrefix = boardNow
                    UsedWords    = {}
                    break
                end

                -- Prefix SAMA = kata ditolak/belum diterima → retry
                pcall(function()
                    FailWords[retryWord] = true
                    if writefile then
                        local ok2, raw = pcall(readfile, "cekfail.txt")
                        local content = (ok2 and raw) and raw or ""
                        writefile("cekfail.txt", content .. retryWord .. "\n")
                    end
                    warn("Fail: " .. retryWord)
                end)

                SavedWords[retryWord] = nil
                UsedWords[retryWord]  = true
                TotalUsed = math.max(0, TotalUsed - 1)

                local next = FindWord(lockedPrefix)
                if not next then
                    CurrentSum = "no candidates"
                    while IsRunning do
                        task.wait(0.3)
                        local bp = GetBoardPrefix()
                        if not bp then lockedPrefix = nil break end
                        if bp ~= lockedPrefix then lockedPrefix = bp UsedWords = {} break end
                    end
                    break
                end

                retryWord  = next
                CurrentSum = "retrying " .. next

                if SelectedMode == "Normal" then
                    PlayNormal(lockedPrefix, next)
                elseif SelectedMode == "Mid" then
                    PlayMid(lockedPrefix, next)
                else
                    PlayRisk(lockedPrefix, next)
                end
            end
        end
        CurrentSum = "stopped"
    end)
end

local function StopAuto()
    IsRunning = false
    if AutoTask then
        task.cancel(AutoTask)
        AutoTask = nil
    end
end

