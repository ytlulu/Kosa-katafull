local function buildMainUI()
    clearContainer()
    local y = 10

    local function mkNumberInput(parent, labelText, yOff, defaultVal, step, minVal, maxVal, onChange)
        local bg = Instance.new("Frame")
        bg.Size = UDim2.new(1, -16, 0, 30)
        bg.Position = UDim2.new(0, 8, 0, yOff)
