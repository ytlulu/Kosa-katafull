local settMenuBtn = mkMenuBtn("🎯 Settings",100)

local function setActiveMenu(btn)
    for _, b in ipairs({mainMenuBtn, miscMenuBtn, settMenuBtn}) do
        b.BackgroundTransparency = 1
        b.TextColor3 = Color3.fromRGB(80, 90, 120)
    end
    btn.BackgroundTransparency = 0
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
end

