local function showToast(msg, color)
    color = color or Color3.fromRGB(30, 30, 40)
    table.insert(toastQueue, {msg = msg, color = color})
    if toastRunning then return end
    toastRunning = true
    task.spawn(function()
        while #toastQueue > 0 do
            local item = table.remove(toastQueue, 1)

            local toast = Instance.new("Frame")
            toast.Size = UDim2.new(0, 220, 0, 36)
            toast.Position = UDim2.new(1, -10, 1, 10)
            toast.AnchorPoint = Vector2.new(1, 1)
