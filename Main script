local function BuildSourceIndex(words)
    local idx = {}
    for _, word in ipairs(words) do
        local first = string.upper(string.sub(word, 1, 1))
        if not idx[first] then idx[first] = {} end
        table.insert(idx[first], word)
    end
    return idx
end

local function BuildCombinedIndex()
    KATA_INDEX = {}
    for _, word in ipairs(KOSA_KATA) do
        local first = string.upper(string.sub(word, 1, 1))
        if not KATA_INDEX[first] then KATA_INDEX[first] = {} end
        table.insert(KATA_INDEX[first], word)
    end
end

local function LoadKata(statusLabel)
    task.spawn(function()
        task.wait(0.3)
        if statusLabel then statusLabel.Text = "Loading vocabulary..." end

        -- Blacklist
        local blSet = {}
        if KATA_BL_URL and KATA_BL_URL ~= "" then
            local okBL, resBL = pcall(function()
                return game:HttpGet(KATA_BL_URL, true)
            end)
            if okBL and resBL then
                for line in resBL:gmatch("[^\n]+") do
                    local w = line:match("^%s*(.-)%s*$")
                    if w and #w >= 1 then blSet[string.lower(w)] = true end
                end
            end
        end

        KOSA_KATA = {}
        local combinedSeen = {}
        local totalLoaded  = 0

        for _, src in ipairs(KATA_SOURCES) do
            local ok, result = pcall(function()
                return game:HttpGet(src.url, true)
            end)
            if ok and result then
                local srcWords = {}
                local srcSeen  = {}
                for line in result:gmatch("[^\n]+") do
                    local word = line:match("^%s*(.-)%s*$")
                    if word and #word >= 3 then
                        for part in word:gmatch("[^%s%-]+") do
                            local p = string.lower(part)
                            if #p >= 3 and not blSet[p] then
                                -- per-source (boleh duplikat antar source)
                                if not srcSeen[p] then
                                    srcSeen[p] = true
                                    table.insert(srcWords, p)
                                end
                                -- combined (dedup global)
                                if not combinedSeen[p] then
                                    combinedSeen[p] = true
                                    table.insert(KOSA_KATA, p)
                                end
                            end
                        end
                    end
                end
                sourceData[src.name] = {
                    words = srcWords,
                    index = BuildSourceIndex(srcWords),
                }
                totalLoaded = totalLoaded + 1
                print("Loaded", src.name, ":", #srcWords, "kata")
            else
                warn("Gagal load:", src.name)
                sourceData[src.name] = {words = {}, index = {}}
            end
        end

        BuildCombinedIndex()

        -- Build kosaKataSet untuk O(1) lookup di Spy
        kosaKataSet = {}
        for _, w in ipairs(KOSA_KATA) do
            kosaKataSet[w] = true
        end

        print("Total gabungan:", #KOSA_KATA, "kata dari", totalLoaded, "source")
        if statusLabel then
            statusLabel.Text = #KOSA_KATA .. " kata (" .. totalLoaded .. " source)"
            statusLabel.TextColor3 = Color3.fromRGB(50, 180, 80)
        end
    end)
end

