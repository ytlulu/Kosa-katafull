local function buildSettingsUI()
    clearContainer()
    local y = 10

    -- ── "Counter Akhiran" accordion (default open) ────────────
    -- innerH: label(14)+input(30)+counterAvLbl(14)+toggle(40)+desc1(14)+desc2(16) + top(8) = 136
    local ctrBody, nextY = mkAccordion(container, "Counter Akhiran", y, 116, "settCounter")
    local cy = 8

    local inputBg = Instance.new("Frame")
    inputBg.Size = UDim2.new(1, -16, 0, 30)
    inputBg.Position = UDim2.new(0, 8, 0, cy)
    inputBg.BackgroundColor3 = Color3.fromRGB(240, 244, 255)
    inputBg.BorderSizePixel = 0
    inputBg.Parent = ctrBody
    mkCorner(inputBg, 8)
    local inputBox = Instance.new("TextBox")
    inputBox.Size = UDim2.new(1, -16, 1, -8)
    inputBox.Position = UDim2.new(0, 8, 0, 4)
    inputBox.BackgroundTransparency = 1
    inputBox.Text = string.upper(CounterSuffix)
    inputBox.PlaceholderText = "INPUT LAST EX : AI "
    inputBox.Font = Enum.Font.GothamBold
    inputBox.TextSize = 14
    inputBox.TextColor3 = Color3.fromRGB(40, 120, 255)
    inputBox.PlaceholderColor3 = Color3.fromRGB(160, 170, 190)
    inputBox.BorderSizePixel = 0
    inputBox.ClearTextOnFocus = false
    inputBox.TextXAlignment = Enum.TextXAlignment.Center
    inputBox.Parent = inputBg
    cy = cy + 34

    local counterAvLbl = Instance.new("TextLabel")
    counterAvLbl.Size = UDim2.new(1, -16, 0, 14)
    counterAvLbl.Position = UDim2.new(0, 8, 0, cy)
    counterAvLbl.BackgroundTransparency = 1
    counterAvLbl.Text = ""
    counterAvLbl.Font = Enum.Font.Gotham
    counterAvLbl.TextSize = 10
    counterAvLbl.TextColor3 = Color3.fromRGB(40, 120, 255)
    counterAvLbl.TextXAlignment = Enum.TextXAlignment.Left
    counterAvLbl.Parent = ctrBody
    cy = cy + 16

    local function updateCounterAv()
        if not CounterOn or CounterSuffix == "" then counterAvLbl.Text = "" return end
        local suffix = string.lower(CounterSuffix)
        local count = 0
        for _, word in ipairs(KOSA_KATA) do
            if string.sub(word, -#suffix) == suffix then count = count + 1 end
        end
        counterAvLbl.Text = "Counter available: " .. count .. " kata"
    end

    inputBox.FocusLost:Connect(function()
        local val = inputBox.Text:match("^%s*(.-)%s*$") or ""
        val = val:gsub("[^%a]", "")
        CounterSuffix = string.lower(val)
        inputBox.Text = string.upper(CounterSuffix)
        updateCounterAv()
    end)

    mkToggle(ctrBody, "Counter ON", cy, CounterOn, function(v)
        CounterOn = v
        updateCounterAv()
    end)

    y = nextY + 6
    mkDivider(container, y) y = y + 10

    -- ── "Source Priority" accordion (default closed) ──────────
    local options = {"— pilih —"}
    for _, src in ipairs(KATA_SOURCES) do table.insert(options, src.name) end

    local priBody, nextY2 = mkAccordion(container, "Source Priority", y, 84, "settPriority")
    local py = 8

    local ddRow = Instance.new("Frame")
    ddRow.Size = UDim2.new(1, -16, 0, 32)
    ddRow.Position = UDim2.new(0, 8, 0, py)
    ddRow.BackgroundColor3 = Color3.fromRGB(245, 247, 252)
    ddRow.BorderSizePixel = 0
    ddRow.ClipsDescendants = false
    ddRow.Parent = priBody
    mkCorner(ddRow, 8)
    local ddLbl = Instance.new("TextLabel")
    ddLbl.Size = UDim2.new(0.45, 0, 1, 0)
    ddLbl.Position = UDim2.new(0, 8, 0, 0)
    ddLbl.BackgroundTransparency = 1
    ddLbl.Text = "Choose priority"
    ddLbl.Font = Enum.Font.Gotham
    ddLbl.TextSize = 10
    ddLbl.TextColor3 = Color3.fromRGB(40, 50, 70)
    ddLbl.TextXAlignment = Enum.TextXAlignment.Left
    ddLbl.Parent = ddRow
    local selBtn = Instance.new("TextButton")
    selBtn.Size = UDim2.new(0.55, -12, 1, -6)
    selBtn.Position = UDim2.new(0.45, 4, 0, 3)
    selBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
    selBtn.Text = (SelectedPriorityName ~= "" and SelectedPriorityName or "— pilih —") .. " ▾"
    selBtn.Font = Enum.Font.GothamBold
    selBtn.TextSize = 10
    selBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    selBtn.BorderSizePixel = 0
    selBtn.TextTruncate = Enum.TextTruncate.AtEnd
    selBtn.Parent = ddRow
    mkCorner(selBtn, 6)
    py = py + 36

    local dropOpen = false
    local dropMenu  = nil
    local function closeMenu()
        if dropMenu then pcall(function() dropMenu:Destroy() end) dropMenu = nil end
        dropOpen = false
    end
    selBtn.MouseButton1Click:Connect(function()
        if dropOpen then closeMenu() return end
        dropOpen = true
        local itemH  = 26
        local maxH   = math.min(#options, 6) * itemH
        dropMenu = Instance.new("Frame")
        dropMenu.Size = UDim2.new(0, selBtn.AbsoluteSize.X, 0, maxH)
        local fp = mainFrame.AbsolutePosition
        local sp = selBtn.AbsolutePosition
        dropMenu.Position = UDim2.new(0, sp.X - fp.X, 0, sp.Y - fp.Y + selBtn.AbsoluteSize.Y + 2)
        dropMenu.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        dropMenu.BorderSizePixel = 0
        dropMenu.ZIndex = 200
        dropMenu.ClipsDescendants = true
        dropMenu.Parent = mainFrame
        mkCorner(dropMenu, 6)
        local ds = Instance.new("Frame")
        ds.Size = UDim2.new(1, 6, 1, 6)
        ds.Position = UDim2.new(0, -3, 0, -3)
        ds.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
        ds.BackgroundTransparency = 0.85
        ds.BorderSizePixel = 0
        ds.ZIndex = 199
        ds.Parent = dropMenu
        mkCorner(ds, 8)
        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(1, 0, 1, 0)
        scroll.CanvasSize = UDim2.new(0, 0, 0, #options * itemH)
        scroll.BackgroundTransparency = 1
        scroll.BorderSizePixel = 0
        scroll.ScrollBarThickness = 3
        scroll.ScrollBarImageColor3 = Color3.fromRGB(40, 120, 255)
        scroll.ZIndex = 201
        scroll.Parent = dropMenu
        for i, opt in ipairs(options) do
            local ob = Instance.new("TextButton")
            ob.Size = UDim2.new(1, 0, 0, itemH)
            ob.Position = UDim2.new(0, 0, 0, (i-1) * itemH)
            ob.BackgroundTransparency = 1
            ob.Text = opt
            ob.Font = Enum.Font.Gotham
            ob.TextSize = 10
            ob.TextColor3 = (opt == SelectedPriorityName) and Color3.fromRGB(40,120,255) or Color3.fromRGB(40,50,70)
            ob.TextXAlignment = Enum.TextXAlignment.Center
            ob.ZIndex = 202
            ob.Parent = scroll
            makeHover(ob, Color3.fromRGB(255,255,255), Color3.fromRGB(235,242,255))
            ob.BackgroundTransparency = 1
            ob.MouseButton1Click:Connect(function()
                SelectedPriorityName = (opt == "— pilih —") and "" or opt
                selBtn.Text = opt .. " ▾"
                closeMenu()
            end)
        end
    end)

    mkToggle(priBody, "On Priority", py, PriorityOn, function(v) PriorityOn = v end)

    y = nextY2 + 4
    container.CanvasSize = UDim2.new(0, 0, 0, y)
    updateCounterAv()
end

