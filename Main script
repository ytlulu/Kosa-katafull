        showToast("Used words berhasil direset.", Color3.fromRGB(30, 140, 60))
    end)
    rfwBtn.MouseButton1Click:Connect(function()
        local n = 0 for _ in pairs(FailWords) do n = n + 1 end
        FailWords = {}
        showToast("Fail words berhasil direset. (" .. n .. " kata)", Color3.fromRGB(100, 30, 170))
    end)
    y = nextY2 + 6

    mkDivider(container, y) y = y + 10

    -- ── "Tools" accordion (default closed) ───────────────────
    local toolBody, nextY3 = mkAccordion(container, "Tools", y, 44, "miscTools")
    local rlBtn  = mkHalfBtn(toolBody, "RL",                                       0,   8, 8, 32, Color3.fromRGB(40, 160, 80))
    local COL_3D_ON  = Color3.fromRGB(40, 120, 255)
    local COL_3D_OFF = Color3.fromRGB(160, 50, 200)
    local btn3D  = mkHalfBtn(toolBody, Is3DEnabled and "3D  ON" or "3D  OFF",      0.5, 4, 8, 32, Is3DEnabled and COL_3D_ON or COL_3D_OFF)

    rlBtn.MouseButton1Click:Connect(function()
        pcall(function()
            local lighting = game:GetService("Lighting")
            lighting.GlobalShadows = false
            lighting.FogEnd = 100000
            for _, v in ipairs(lighting:GetChildren()) do
                if v:IsA("BlurEffect") or v:IsA("SunRaysEffect")
                   or v:IsA("ColorCorrectionEffect") or v:IsA("DepthOfFieldEffect")
                   or v:IsA("BloomEffect") then pcall(function() v:Destroy() end) end
            end
            local myChar = LocalPlayer.Character
            for _, obj in ipairs(workspace:GetDescendants()) do
                if myChar and obj:IsDescendantOf(myChar) then continue end
                if obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") then
                    pcall(function() obj:Destroy() end)
                end
            end
        end)
        showToast("Reduce Lag berhasil diterapkan.", Color3.fromRGB(20, 120, 50))
    end)

    btn3D.MouseButton1Click:Connect(function()
        Is3DEnabled = not Is3DEnabled
        pcall(function()
            RunService:Set3dRenderingEnabled(Is3DEnabled)
        end)
        if Is3DEnabled then
            btn3D.BackgroundColor3 = COL_3D_ON
            btn3D.Text = "3D  ON"
            showToast("3D rendering aktif.", Color3.fromRGB(40, 120, 255))
        else
            btn3D.BackgroundColor3 = COL_3D_OFF
            btn3D.Text = "3D  OFF"
            showToast("3D rendering dimatikan — lebih ringan!", Color3.fromRGB(160, 50, 200))
        end
    end)
    y = nextY3 + 6

    mkDivider(container, y) y = y + 10

    -- ── "Word Spy" accordion (default closed) ────────────────
    local COL_SPY_OFF = Color3.fromRGB(180, 50, 50)
    local COL_SPY_ON  = Color3.fromRGB(40, 160, 80)
    local spyBody, nextY4 = mkAccordion(container, "Word Spy", y, 44, "miscWordSpy")
    local spyBtn  = mkHalfBtn(spyBody, SpyOn and "Spy  ON" or "Spy  OFF", 0,   8, 8, 32, SpyOn and COL_SPY_ON or COL_SPY_OFF)
    local sendBtn = mkHalfBtn(spyBody, "Send to DC",                       0.5, 4, 8, 32, Color3.fromRGB(88, 101, 200))
    spyBtn.MouseButton1Click:Connect(function()
        if #KOSA_KATA == 0 then
            showToast("Load vocabulary dulu di tab Main.", Color3.fromRGB(180, 80, 30)) return
        end
        SpyOn = not SpyOn
        if SpyOn then
            spyBtn.BackgroundColor3 = COL_SPY_ON
            spyBtn.Text = "Spy  ON"
            spyPanel.Visible = true
            spyLbl_Count.Text = "Collected : " .. #spyList
            spyStartAll()
            showToast("Spy aktif — memantau " .. #Players:GetPlayers() .. " player.", Color3.fromRGB(40, 160, 80))
        else
            spyBtn.BackgroundColor3 = COL_SPY_OFF
            spyBtn.Text = "Spy  OFF"
            spyPanel.Visible = false
            spyStopAll()
            showToast("Spy dinonaktifkan.", Color3.fromRGB(100, 100, 120))
        end
    end)
    sendBtn.MouseButton1Click:Connect(function()
        if #spyList == 0 then
            showToast("Belum ada kata baru yang terkumpul.", Color3.fromRGB(100, 100, 120)) return
        end
        local snapshot = spyList
        spyList = {} spyWords = {} spyDirty = false
        pcall(writefile, SPY_FILE, "[]")
        task.spawn(function() spySendDC(snapshot) end)
        showToast("Mengirim " .. #snapshot .. " kata ke Discord.", Color3.fromRGB(88, 101, 200))
    end)
    y = nextY4 + 6

    mkDivider(container, y) y = y + 10

    container.CanvasSize = UDim2.new(0, 0, 0, y)
end

