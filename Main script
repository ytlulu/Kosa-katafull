                    end
                end
            end
            infoLbl_Av.Text  = "Av   : " .. avCount

            local usCount = TotalUsed
            infoLbl_Us.Text  = "Us   : " .. usCount

            if currentWordLabel then
                local cur = currentWordLabel.Text:gsub("📝 ",""):gsub("⏳.*","—"):gsub("⏸.*","—")
                infoLbl_Sum.Text = "Sum  : " .. cur
            end
        end
    end
end)

