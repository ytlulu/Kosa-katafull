    y = y + 46

    mkDivider(container, y)
    y = y + 12

    -- Current word display
    mkLabel(container, "Kata saat ini:", y, 18, 11, false, Color3.fromRGB(100,110,140))
    y = y + 22

    local wordBox = Instance.new("Frame")
    wordBox.Size = UDim2.new(1, -16, 0, 38)
    wordBox.Position = UDim2.new(0, 8, 0, y)
    wordBox.BackgroundColor3 = Color3.fromRGB(240, 244, 255)
    wordBox.BorderSizePixel = 0
    wordBox.Parent = container
    mkCorner(wordBox, 8)

    local wordLbl = Instance.new("TextLabel")
    wordLbl.Size = UDim2.new(1, -12, 1, 0)
    wordLbl.Position = UDim2.new(0, 6, 0, 0)
    wordLbl.BackgroundTransparency = 1
    wordLbl.Text = "⏳ Belum jalan..."
    wordLbl.Font = Enum.Font.GothamBold
    wordLbl.TextSize = 13
    wordLbl.TextColor3 = Color3.fromRGB(40, 120, 255)
    wordLbl.TextXAlignment = Enum.TextXAlignment.Left
    wordLbl.Parent = wordBox
    currentWordLabel = wordLbl
    y = y + 48

    mkDivider(container, y)
    y = y + 12

    -- Status kata loaded
    local statusLbl = mkLabel(container, "⏳ Memuat kosa kata...", y, 20, 11, false, Color3.fromRGB(130,140,160))
    y = y + 28

    container.CanvasSize = UDim2.new(0, 0, 0, y)

    -- trigger load
    LoadKata(statusLbl)
end

