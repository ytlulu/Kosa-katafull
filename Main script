-- BUILD MAIN TAB
-- ============================================================
local function buildMainUI()
    clearContainer()
    local y = 12

    mkLabel(container, "Mode Auto", y, 20, 11, false, Color3.fromRGB(100,110,140))
    y = y + 24

    -- Mode selector: 3 tombol horizontal
    local MODES = {"Normal", "Mid", "Brutal"}
    local modeButtons = {}
    local modeBg = Instance.new("Frame")
    modeBg.Size = UDim2.new(1, -16, 0, 36)
    modeBg.Position = UDim2.new(0, 8, 0, y)
    modeBg.BackgroundColor3 = Color3.fromRGB(235, 238, 248)
    modeBg.BorderSizePixel = 0
    modeBg.Parent = container
    mkCorner(modeBg, 8)

    local COL_ON  = Color3.fromRGB(40, 180, 80)
    local COL_OFF = Color3.fromRGB(160, 165, 180)
    local btnW = math.floor((1/#MODES) * 100)

    local function refreshModeButtons()
        for _, info in ipairs(modeButtons) do
            local isActive = (info.mode == SelectedMode)
            TweenService:Create(info.btn, TweenInfo.new(0.15), {
                BackgroundColor3 = isActive and COL_ON or COL_OFF
            }):Play()
        end
    end

    for i, modeName in ipairs(MODES) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1/#MODES, i < #MODES and -2 or 0, 1, -6)
        btn.Position = UDim2.new((i-1)/#MODES, i == 1 and 3 or 1, 0, 3)
        btn.BackgroundColor3 = (modeName == SelectedMode) and COL_ON or COL_OFF
        btn.Text = modeName
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 12
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.BorderSizePixel = 0
        btn.Parent = modeBg
        mkCorner(btn, 6)
        table.insert(modeButtons, {btn = btn, mode = modeName})

        btn.MouseButton1Click:Connect(function()
            SelectedMode = modeName
            refreshModeButtons()
        end)
    end
    y = y + 46

    mkDivider(container, y)
    y = y + 12

    -- ===== SETTINGS =====
    mkLabel(container, "Settings", y, 20, 11, false, Color3.fromRGB(100,110,140))
    y = y + 24

    -- Helper: number input row
    local function mkNumberInput(labelText, yOff, defaultVal, step, minVal, maxVal, onChange)
        local bg = Instance.new("Frame")
        bg.Size = UDim2.new(1, -16, 0, 36)
        bg.Position = UDim2.new(0, 8, 0, yOff)
        bg.BackgroundColor3 = Color3.fromRGB(245, 247, 252)
        bg.BorderSizePixel = 0
        bg.Parent = container
        mkCorner(bg, 8)

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(0.55, 0, 1, 0)
        lbl.Position = UDim2.new(0, 10, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = labelText
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 12
        lbl.TextColor3 = Color3.fromRGB(40, 50, 70)
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = bg

        local minusBtn = Instance.new("TextButton")
        minusBtn.Size = UDim2.new(0, 26, 0, 26)
        minusBtn.Position = UDim2.new(1, -110, 0.5, -13)
        minusBtn.Text = "−"
        minusBtn.Font = Enum.Font.GothamBold
        minusBtn.TextSize = 16
        minusBtn.BackgroundColor3 = Color3.fromRGB(200, 210, 230)
        minusBtn.TextColor3 = Color3.fromRGB(40, 50, 70)
        minusBtn.BorderSizePixel = 0
        minusBtn.Parent = bg
        mkCorner(minusBtn, 6)

        local valLabel = Instance.new("TextLabel")
        valLabel.Size = UDim2.new(0, 46, 0, 26)
        valLabel.Position = UDim2.new(1, -80, 0.5, -13)
        valLabel.BackgroundTransparency = 1
        valLabel.Text = tostring(defaultVal)
        valLabel.Font = Enum.Font.GothamBold
        valLabel.TextSize = 13
        valLabel.TextColor3 = Color3.fromRGB(40, 120, 255)
        valLabel.TextXAlignment = Enum.TextXAlignment.Center
        valLabel.Parent = bg

        local plusBtn = Instance.new("TextButton")
        plusBtn.Size = UDim2.new(0, 26, 0, 26)
        plusBtn.Position = UDim2.new(1, -30, 0.5, -13)
        plusBtn.Text = "+"
        plusBtn.Font = Enum.Font.GothamBold
        plusBtn.TextSize = 16
        plusBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
        plusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        plusBtn.BorderSizePixel = 0
        plusBtn.Parent = bg
        mkCorner(plusBtn, 6)

        local cur = {defaultVal}
        local function update(v)
            v = math.clamp(math.floor(v / step + 0.5) * step, minVal, maxVal)
            v = math.floor(v * 100 + 0.5) / 100
            cur[1] = v
            valLabel.Text = tostring(v)
            onChange(v)
        end

        minusBtn.MouseButton1Click:Connect(function() update(cur[1] - step) end)
        plusBtn.MouseButton1Click:Connect(function()  update(cur[1] + step) end)
        return bg
    end

    mkNumberInput("Delay (board muncul)", y, CFG.Delay, 0.1, 0, 3, function(v)
        CFG.Delay = v
    end)
    y = y + 44

    mkNumberInput("Speed (per karakter)", y, CFG.Speed, 0.05, 0.01, 1, function(v)
