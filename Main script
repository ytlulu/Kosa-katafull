    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 13
    lbl.TextColor3 = Color3.fromRGB(40, 50, 70)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = bg

    local valBtn = Instance.new("TextButton")
    valBtn.Size = UDim2.new(0, 110, 0, 28)
    valBtn.Position = UDim2.new(1, -118, 0.5, -14)
    valBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
    valBtn.Text = default .. " ▾"
    valBtn.Font = Enum.Font.GothamBold
    valBtn.TextSize = 12
    valBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    valBtn.BorderSizePixel = 0
    valBtn.Parent = bg
    mkCorner(valBtn, 6)

    -- dropMenu di-parent ke rightPanel supaya tidak ter-clip scroll/container
    -- posisi dihitung saat dibuka
    local dropMenu = Instance.new("Frame")
    dropMenu.Size = UDim2.new(0, 110, 0, #options * 32)
    dropMenu.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    dropMenu.BorderSizePixel = 0
    dropMenu.Visible = false
    dropMenu.ZIndex = 200
    mkCorner(dropMenu, 8)

    -- shadow
    local ds = Instance.new("Frame")
    ds.Size = UDim2.new(1, 8, 1, 8)
    ds.Position = UDim2.new(0, -4, 0, -4)
    ds.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
    ds.BackgroundTransparency = 0.85
    ds.BorderSizePixel = 0
    ds.ZIndex = 199
    ds.Parent = dropMenu
    mkCorner(ds, 10)

    for i, opt in ipairs(options) do
        local ob = Instance.new("TextButton")
        ob.Size = UDim2.new(1, 0, 0, 32)
        ob.Position = UDim2.new(0, 0, 0, (i-1)*32)
        ob.BackgroundTransparency = 1
        ob.Text = opt
        ob.Font = Enum.Font.Gotham
        ob.TextSize = 13
        ob.TextColor3 = Color3.fromRGB(40, 50, 70)
        ob.ZIndex = 201
        ob.Parent = dropMenu
        makeHover(ob, Color3.fromRGB(255,255,255), Color3.fromRGB(235,240,255))
        ob.BackgroundTransparency = 1

        ob.MouseButton1Click:Connect(function()
            selected[1] = opt
            valBtn.Text = opt .. " ▾"
            dropMenu.Visible = false
            dropMenu.Parent = nil
            open[1] = false
            callback(opt)
        end)
    end

    valBtn.MouseButton1Click:Connect(function()
        open[1] = not open[1]
        if open[1] then
            -- Posisi absolut valBtn relatif ke mainFrame
            local absPos = valBtn.AbsolutePosition
            local framePos = mainFrame.AbsolutePosition
            local rx = absPos.X - framePos.X
            local ry = absPos.Y - framePos.Y + valBtn.AbsoluteSize.Y + 4
            dropMenu.Position = UDim2.new(0, rx, 0, ry)
            dropMenu.Parent = mainFrame
            dropMenu.Visible = true
        else
            dropMenu.Visible = false
            dropMenu.Parent = nil
        end
    end)

    return bg, 36
end

