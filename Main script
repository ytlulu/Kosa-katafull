    Speed      = 0.10,  -- interval per karakter BillboardUpdate (Normal mode)
    FireSpeed  = 0.6,   -- jeda antar submit kata
    RetryDelay = 1.0,   -- jeda sebelum retry setelah gagal
}

-- ============================================================
-- LOAD KOSA KATA
-- ============================================================
local KATA_URL  = "https://raw.githubusercontent.com/ytlulu/Kosa-katafull/main/for20%update.txt"
local KOSA_KATA = {}
local KATA_INDEX= {}

local function BuildIndex()
    KATA_INDEX = {}
    for _, word in ipairs(KOSA_KATA) do
        local first = string.upper(string.sub(word, 1, 1))
        if not KATA_INDEX[first] then KATA_INDEX[first] = {} end
        table.insert(KATA_INDEX[first], word)
    end
end

local function LoadKata(statusLabel)
    task.spawn(function()
        task.wait(0.3)
        if statusLabel then statusLabel.Text = "⏳ Memuat kosa kata..." end
        local ok, result = pcall(function()
            return game:HttpGet(KATA_URL, true)
        end)
        if not ok or not result then
            warn("Gagal load kata")
            if statusLabel then statusLabel.Text = "❌ Gagal load kosa kata!" end
            return
        end
        KOSA_KATA = {}
        local seen = {}
        for line in result:gmatch("[^\n]+") do
            local word = line:match("^%s*(.-)%s*$")
            if word and #word >= 2 then
                local hasSpace = word:find("%s")
                if hasSpace then
                    for part in word:gmatch("%S+") do
                        local p = string.lower(part)
                        if #p >= 2 and not seen[p] then
                            seen[p] = true
                            table.insert(KOSA_KATA, p)
                        end
                    end
                else
                    local w = string.lower(word)
                    if not seen[w] then
                        seen[w] = true
                        table.insert(KOSA_KATA, w)
                    end
                end
            end
        end
        BuildIndex()
        print("✅ Loaded kata:", #KOSA_KATA)
        if statusLabel then
            statusLabel.Text = "✅ " .. #KOSA_KATA .. " kata dimuat"
            statusLabel.TextColor3 = Color3.fromRGB(50, 180, 80)
        end
    end)
end

-- ============================================================
-- GAME LOGIC
-- ============================================================
local function DetectPlayer()
    if LocalPlayer.Character then
        return LocalPlayer.Character.Name
    end
    return nil
end

local function GetBoardPrefix()
    if AutoDetect then Username = DetectPlayer() end
    if not Username or Username == "" then return nil end
    local ok, prefix = pcall(function()
        local target = workspace:FindFirstChild(Username)
        if not target then return nil end
        local head = target:FindFirstChild("Head")
        if not head then return nil end
        local billboard = head:FindFirstChild("TurnBillboard")
        if not billboard then return nil end
        local label = billboard:FindFirstChildWhichIsA("TextLabel", true)
        if not label then return nil end
        local text = label.Text
        if not text or text == "" then return nil end
        -- Ambil seluruh teks board (huruf kapital semua), bukan cuma 1 huruf
        return string.upper(text:match("^%s*(.-)%s*$") or "")
    end)
    if ok and prefix and #prefix > 0 then return prefix end
    return nil
end

local function FindWord(prefix)
    if not prefix or #prefix == 0 then return nil end
    local lowerPrefix = string.lower(prefix)
    local firstLetter = string.upper(string.sub(prefix, 1, 1))
    local candidates = KATA_INDEX[firstLetter] or {}

    local available = {}
    for _, word in ipairs(candidates) do
        if string.sub(word, 1, #lowerPrefix) == lowerPrefix
            and not UsedWords[word] and not SavedWords[word] then
            -- Filter suffix kalau Counter ON
            if CounterOn and CounterSuffix ~= "" then
                local lastChar = string.sub(word, -1)
                if lastChar ~= string.lower(CounterSuffix) then
                    continue
                end
            end
            table.insert(available, word)
        end
    end
    -- Fallback: kalau tidak ada kata yang match suffix, cari tanpa filter suffix
    if #available == 0 and CounterOn and CounterSuffix ~= "" then
        for _, word in ipairs(candidates) do
            if string.sub(word, 1, #lowerPrefix) == lowerPrefix
                and not UsedWords[word] and not SavedWords[word] then
                table.insert(available, word)
            end
        end
    end
    if #available == 0 then return nil end
    local picked = available[math.random(#available)]
    UsedWords[picked] = true
    return picked
end

local function Submit(word)
    pcall(function()
        ReplicatedStorage.Remotes.SubmitWord:FireServer(word)
    end)
    SavedWords[word] = true
    TotalUsed = TotalUsed + 1
end

local function PlayNormal(word, startFrom)
    if not word then return end
    task.wait(CFG.Delay)
    -- startFrom = panjang prefix yang sudah ada di billboard, mulai dari situ
    local from = startFrom or 0
    for i = from + 1, #word do
        if not IsRunning then return end
        local partial = string.sub(word, 1, i)
        pcall(function()
            ReplicatedStorage.Remotes.BillboardUpdate:FireServer(partial)
        end)
        task.wait(CFG.Speed)
    end
    task.wait(0.1)
    Submit(word)
end

local function PlayMid(word)
    if not word then return end
    task.wait(CFG.Delay)
    pcall(function()
        ReplicatedStorage.Remotes.BillboardUpdate:FireServer(word)
    end)
    task.wait(0.2)
    Submit(word)
end

local function PlayRisk(word)
    if not word then return end
    task.wait(CFG.Delay)
    Submit(word)
end

local currentWordLabel = nil  -- diisi setelah GUI dibuat

local function StartAuto()
    if IsRunning then return end
    IsRunning = true
    AutoTask = task.spawn(function()
        local lastPrefix = nil
        while IsRunning do
            local prefix = GetBoardPrefix()
            if prefix then
                if prefix ~= lastPrefix then
                    lastPrefix = prefix
                    UsedWords  = {}
                end
                local word = FindWord(prefix)
                if word then
                    if currentWordLabel then
                        currentWordLabel.Text = "📝 " .. word
                    end
                    if SelectedMode == "Normal" then
                        PlayNormal(word, #prefix)
                    elseif SelectedMode == "Mid" then
                        PlayMid(word)
                    else
                        PlayRisk(word)
                    end
                    task.wait(CFG.FireSpeed)

                    -- Cek gagal
                    local afterPrefix = GetBoardPrefix()
                    if afterPrefix and afterPrefix == lastPrefix and IsRunning then
                        if currentWordLabel then
                            currentWordLabel.Text = "❌ Gagal, retry..."
                        end
                        pcall(function()
                            ReplicatedStorage.Remotes.BillboardUpdate:FireServer(lastPrefix)
                        end)
                        task.wait(CFG.RetryDelay)
                        SavedWords[word] = nil
                        TotalUsed = math.max(0, TotalUsed - 1)
                    end
                    continue
                end
            else
                lastPrefix = nil
                if currentWordLabel then currentWordLabel.Text = "⏳ Menunggu board..." end
            end
            task.wait(0.3)
        end
        if currentWordLabel then currentWordLabel.Text = "⏸ Stopped" end
    end)
end

local function StopAuto()
    IsRunning = false
    if AutoTask then
        task.cancel(AutoTask)
        AutoTask = nil
    end
end

