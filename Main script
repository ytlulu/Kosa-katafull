local function makeHover(btn, base, hov)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = hov}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = base}):Play()
    end)
end

local function mkCorner(parent, radius)
    local c = Instance.new("UICorner", parent)
    c.CornerRadius = UDim.new(0, radius or 8)
    return c
end

local function mkLabel(parent, text, yOff, h, size, bold, color)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, -16, 0, h)
    l.Position = UDim2.new(0, 8, 0, yOff)
    l.BackgroundTransparency = 1
    l.Text = text
    l.Font = bold and Enum.Font.GothamBold or Enum.Font.Gotham
    l.TextSize = size or 13
    l.TextColor3 = color or Color3.fromRGB(40, 50, 70)
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = parent
    return l
end

local function mkBtn(parent, text, yOff, h, col)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -16, 0, h)
    b.Position = UDim2.new(0, 8, 0, yOff)
    b.BackgroundColor3 = col or Color3.fromRGB(40, 120, 255)
    b.Text = text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 13
    b.TextColor3 = Color3.fromRGB(255, 255, 255)
    b.BorderSizePixel = 0
    b.Parent = parent
    mkCorner(b, 8)
    local hov = Color3.fromRGB(
        math.clamp(col and col.R*255+25 or 65, 0, 255),
        math.clamp(col and col.G*255+25 or 145, 0, 255),
        math.clamp(col and col.B*255+25 or 255, 0, 255)
    )
    makeHover(b, col or Color3.fromRGB(40,120,255), hov)
    return b
end

