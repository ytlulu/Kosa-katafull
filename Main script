task.spawn(function()
    local lastBillForAv = ""
    local cachedAvCount = 0
    while true do
        task.wait(0.5)
        if not infoPanel or not infoPanel.Parent then break end
        -- FPS snapshot tiap 0.5s
        _fpsCurrent = _fpsCount * 2   -- count per 0.5s → *2 = per second
        _fpsCount   = 0
        if infoPanel.Visible then
            infoLbl_Bill.Text = "Bill : " .. CurrentBill
            infoLbl_Sum.Text  = "Sum  : " .. CurrentSum
            if CurrentBill ~= lastBillForAv then
                lastBillForAv = CurrentBill
                cachedAvCount = 0
                if CurrentBill ~= "—" then
                    local lp = string.lower(CurrentBill)
                    local fl = string.upper(string.sub(CurrentBill, 1, 1))
                    local bucket = KATA_INDEX[fl] or {}
                    for _, w in ipairs(bucket) do
                        if string.sub(w, 1, #lp) == lp and not UsedWords[w] and not SavedWords[w] and not FailWords[w] then
                            cachedAvCount = cachedAvCount + 1
                        end
                    end
                end
            end
            infoLbl_Av.Text  = "Av   : " .. cachedAvCount
            infoLbl_Us.Text  = "Us   : " .. TotalUsed
            infoLbl_FPS.Text = tostring(_fpsCurrent)
            -- CPU: frame time dari RenderStepped dt (ms)
            infoLbl_CPU.Text  = tostring(math.floor(_lastDt * 1000))
            -- Ping: pakai LocalPlayer:GetNetworkPing() (ms)
            local pingMs = 0
            pcall(function()
                pingMs = math.floor(LocalPlayer:GetNetworkPing() * 1000)
            end)
            infoLbl_Ping.Text = tostring(pingMs)
        end
    end
end)

