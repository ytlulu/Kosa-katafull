        lbl.Position = UDim2.new(0, 8, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = labelText
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 10
        lbl.TextColor3 = Color3.fromRGB(40, 50, 70)
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.Parent = bg
        local minusBtn = Instance.new("TextButton")
        minusBtn.Size = UDim2.new(0, 22, 0, 22)
        minusBtn.Position = UDim2.new(1, -90, 0.5, -11)
        minusBtn.Text = "−"
        minusBtn.Font = Enum.Font.GothamBold
        minusBtn.TextSize = 14
        minusBtn.BackgroundColor3 = Color3.fromRGB(200, 210, 230)
        minusBtn.TextColor3 = Color3.fromRGB(40, 50, 70)
        minusBtn.BorderSizePixel = 0
        minusBtn.Parent = bg
        mkCorner(minusBtn, 5)
        local valLabel = Instance.new("TextLabel")
        valLabel.Size = UDim2.new(0, 38, 0, 22)
        valLabel.Position = UDim2.new(1, -64, 0.5, -11)
        valLabel.BackgroundTransparency = 1
        valLabel.Text = tostring(defaultVal)
        valLabel.Font = Enum.Font.GothamBold
        valLabel.TextSize = 11
        valLabel.TextColor3 = Color3.fromRGB(40, 120, 255)
        valLabel.TextXAlignment = Enum.TextXAlignment.Center
        valLabel.Parent = bg
        local plusBtn = Instance.new("TextButton")
        plusBtn.Size = UDim2.new(0, 22, 0, 22)
        plusBtn.Position = UDim2.new(1, -26, 0.5, -11)
        plusBtn.Text = "+"
        plusBtn.Font = Enum.Font.GothamBold
        plusBtn.TextSize = 14
        plusBtn.BackgroundColor3 = Color3.fromRGB(40, 120, 255)
        plusBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        plusBtn.BorderSizePixel = 0
        plusBtn.Parent = bg
        mkCorner(plusBtn, 5)
        local cur = {defaultVal}
        local function update(v)
            v = math.clamp(math.floor(v / step + 0.5) * step, minVal, maxVal)
            v = math.floor(v * 100 + 0.5) / 100
            cur[1] = v
            valLabel.Text = tostring(v)
            onChange(v)
        end
        minusBtn.MouseButton1Click:Connect(function() update(cur[1] - step) end)
        plusBtn.MouseButton1Click:Connect(function()  update(cur[1] + step) end)
        return bg
    end

    -- ── "Game" accordion (default open): Mode + Word Length ──
    local gameBody, nextY = mkAccordion(container, "Game", y, 120, "mainGame")
    local gy = 8
    local COL_ON  = Color3.fromRGB(40, 180, 80)
    local COL_OFF = Color3.fromRGB(160, 165, 180)
    -- Mode
    local modeLabel = Instance.new("TextLabel")
    modeLabel.Size = UDim2.new(1, -16, 0, 14)
    modeLabel.Position = UDim2.new(0, 8, 0, gy)
    modeLabel.BackgroundTransparency = 1
    modeLabel.Text = "Mode"
    modeLabel.Font = Enum.Font.Gotham
    modeLabel.TextSize = 10
    modeLabel.TextColor3 = Color3.fromRGB(100, 110, 140)
    modeLabel.TextXAlignment = Enum.TextXAlignment.Left
    modeLabel.Parent = gameBody
    gy = gy + 16
    local MODES = {"Normal", "Mid", "Brutal"}
    local modeButtons = {}
    local modeBg = Instance.new("Frame")
    modeBg.Size = UDim2.new(1, -16, 0, 30)
    modeBg.Position = UDim2.new(0, 8, 0, gy)
    modeBg.BackgroundColor3 = Color3.fromRGB(235, 238, 248)
    modeBg.BorderSizePixel = 0
    modeBg.Parent = gameBody
    mkCorner(modeBg, 8)
    local function refreshModeButtons()
        for _, info in ipairs(modeButtons) do
            info.btn.BackgroundColor3 = (info.mode == SelectedMode) and COL_ON or COL_OFF
        end
    end
    for i, modeName in ipairs(MODES) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1/#MODES, i < #MODES and -2 or 0, 1, -6)
        btn.Position = UDim2.new((i-1)/#MODES, i == 1 and 3 or 1, 0, 3)
        btn.BackgroundColor3 = (modeName == SelectedMode) and COL_ON or COL_OFF
        btn.Text = modeName
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 10
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.BorderSizePixel = 0
        btn.Parent = modeBg
        mkCorner(btn, 6)
        table.insert(modeButtons, {btn = btn, mode = modeName})
        btn.MouseButton1Click:Connect(function()
            SelectedMode = modeName
            refreshModeButtons()
        end)
    end
    gy = gy + 34
    -- Word Length
    local lenLabel = Instance.new("TextLabel")
    lenLabel.Size = UDim2.new(1, -16, 0, 14)
    lenLabel.Position = UDim2.new(0, 8, 0, gy)
    lenLabel.BackgroundTransparency = 1
    lenLabel.Text = "Priority Used"
    lenLabel.Font = Enum.Font.Gotham
    lenLabel.TextSize = 10
    lenLabel.TextColor3 = Color3.fromRGB(100, 110, 140)
    lenLabel.TextXAlignment = Enum.TextXAlignment.Left
    lenLabel.Parent = gameBody
    gy = gy + 16
    local LENGTHS = {"Short", "Any", "Long"}
    local lenButtons = {}
    local lenBg = Instance.new("Frame")
    lenBg.Size = UDim2.new(1, -16, 0, 30)
    lenBg.Position = UDim2.new(0, 8, 0, gy)
    lenBg.BackgroundColor3 = Color3.fromRGB(235, 238, 248)
    lenBg.BorderSizePixel = 0
    lenBg.Parent = gameBody
    mkCorner(lenBg, 8)
    local COL_LEN_ON  = Color3.fromRGB(40, 120, 255)
    local COL_LEN_OFF = Color3.fromRGB(160, 165, 180)
    local function refreshLenButtons()
        for _, info in ipairs(lenButtons) do
            info.btn.BackgroundColor3 = (info.len == WordLength) and COL_LEN_ON or COL_LEN_OFF
        end
    end
    for i, lenName in ipairs(LENGTHS) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1/#LENGTHS, i < #LENGTHS and -2 or 0, 1, -6)
        btn.Position = UDim2.new((i-1)/#LENGTHS, i == 1 and 3 or 1, 0, 3)
        btn.BackgroundColor3 = (lenName == WordLength) and COL_LEN_ON or COL_LEN_OFF
        btn.Text = lenName
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 10
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.BorderSizePixel = 0
        btn.Parent = lenBg
        mkCorner(btn, 6)
        table.insert(lenButtons, {btn = btn, len = lenName})
        btn.MouseButton1Click:Connect(function()
            WordLength = lenName
            refreshLenButtons()
        end)
    end
    y = nextY + 6

    mkDivider(container, y)
    y = y + 10

    -- ── "Settings" accordion (default closed): Delay/Speed/Fire ──
    local settBody, nextY2 = mkAccordion(container, "Settings", y, 116, "mainSettings")
    local sy = 8
    mkNumberInput(settBody, "Delay",      sy, CFG.Delay,     0.1,  0,    3, function(v) CFG.Delay = v end)     sy = sy + 36
    mkNumberInput(settBody, "Speed",      sy, CFG.Speed,     0.01, 0.01, 1, function(v) CFG.Speed = v end)     sy = sy + 36
    mkNumberInput(settBody, "Fire Speed", sy, CFG.FireSpeed, 0.1,  0.1,  5, function(v) CFG.FireSpeed = v end) sy = sy + 36
    y = nextY2 + 6

    mkDivider(container, y)
    y = y + 10

    -- Start Auto (selalu visible)
    mkToggle(container, "Start Auto", y, IsRunning, function(on)
        if on then StartAuto() else StopAuto() end
    end)
    y = y + 40

    mkDivider(container, y)
    y = y + 10

    local statusSbl = mkLabel(container, "Loading vocabulary...", y, 16, 10, false, Color3.fromRGB(130,140,160))
    y = y + 22
    container.CanvasSize = UDim2.new(0, 0, 0, y)

    if #KOSA_KATA == 0 then
        LoadKata(statusSbl)
    else
        statusSbl.Text = #KOSA_KATA .. " kata (" .. #KATA_SOURCES .. " source)"
        statusSbl.TextColor3 = Color3.fromRGB(50, 180, 80)
    end
end

